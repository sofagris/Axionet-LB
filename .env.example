# AxioNet LB – example environment
# Copy to .env and adjust as needed.

# SQLite path inside the API container (also bind-mounted from host)
AX_LB_DATA_DIR=/var/lib/ax-lb
DATABASE_URL=sqlite:////var/lib/ax-lb/ax-lb.db

# API
AX_API_HOST=0.0.0.0
AX_API_PORT=8000
AX_LOG_LEVEL=INFO

# Docker Engine (mounted socket in compose)
DOCKER_HOST=unix:///var/run/docker.sock

# Host sysfs for NIC discovery (bind-mounted as /host/sys in compose)
HOST_SYSFS_ROOT=/host/sys

# GUI → API (used by nginx in the gui container)
AX_API_UPSTREAM=http://api:8000
