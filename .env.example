# AxioNet LB – example environment
# Copy to .env and adjust as needed.

# SQLite path inside the API container (also bind-mounted from host)
AX_LB_DATA_DIR=/var/lib/ax-lb
DATABASE_URL=sqlite:////var/lib/ax-lb/ax-lb.db

# API
AX_API_HOST=0.0.0.0
AX_API_PORT=8000
AX_LOG_LEVEL=INFO

# Docker Engine (mounted socket in compose)
DOCKER_HOST=unix:///var/run/docker.sock

# Host sysfs for NIC discovery (bind-mounted as /host/sys in compose)
HOST_SYSFS_ROOT=/host/sys

# Use nsenter into host PID 1 netns for VLAN device management
HOST_NET_NSENTER=true

# GUI publish address (management interface IPv4). Default all interfaces for bootstrap.
# After POST /api/v1/interfaces/{id}/promote-management, use the written value from
# /var/lib/ax-lb/mgmt-bind.env and recreate the gui service.
MGMT_BIND_IP=0.0.0.0

# GUI → API (used by nginx in the gui container)
AX_API_UPSTREAM=http://api:8000
